rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección de movimientos
    match /movimientos/{movimientoId} {
      // Solo usuarios autenticados pueden leer sus propios movimientos
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      // Solo pueden crear movimientos asociados a su propio uid
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'fecha', 'tipo', 'categoria', 'concepto', 'valor'])
                    && request.resource.data.tipo in ['Ingreso', 'Gasto']
                    && request.resource.data.valor is number
                    && request.resource.data.valor >= 0;

      // Solo pueden actualizar sus propios movimientos sin cambiar el uid
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;

      // Solo pueden eliminar sus propios movimientos
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // Reglas para la colección de presupuestos
    match /presupuestos/{presupuestoId} {
      // resource == null permite leer cuando el documento aún no existe
      allow read: if request.auth != null
                  && (resource == null || resource.data.uid == request.auth.uid);

      allow create, update: if request.auth != null
                            && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // Reglas para la colección de bolsillos
    match /bolsillos/{bolsilloId} {
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'nombre'])
                    && request.resource.data.saldo is number;

      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    // Reglas para la colección de suscripciones
    match /suscripciones/{suscripcionId} {
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'nombre', 'monto', 'frecuencia', 'proximoPago'])
                    && request.resource.data.monto is number;

      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }
  }
}
